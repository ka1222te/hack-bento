# ===== HackBento 環境設定テンプレート =====
# cp .env.example .env  してから値を埋めてください

# --- アプリ ---
APP_TITLE=HackBento

# --- サーバ ---
DOMAIN=localhost
SCHEME=http
PORT=8000

# --- タイムアウト・制限 ---
DEFAULT_TIMEOUT_MINUTES=60
TIMEOUT_WARNING_MINUTES=10
MAX_ENVS_PER_USER=2
MAX_ENVS_TOTAL=20
VM_CPU_LIMIT=1
VM_MEMORY_LIMIT_MB=1024

# --- セキュリティ ---
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- DB ---
DATABASE_URL=sqlite+aiosqlite:////data/db/hackbento.db

# --- LDAP ---
LDAP_ENABLED=false
LDAP_URI="ldap://example.com:389"
LDAP_TOP_DOMAIN="dc=example,dc=com"
LDAP_USER_FILTER="(uid={username})"
LDAP_OU_USER="people"
LDAP_OU_GROUP="groups"

# --- Google OAuth2 ---
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
OAUTH_ALLOWED_DOMAINS=

# --- バックエンド ---
## 現在は docker のみサポート
VM_BACKEND=docker

# --- macvlan / VM IPプール ---
## macvlan ネットワーク設定（物理NI・サブネット等）は docker-compose.yml の networks: で管理
## MACVLAN_NETWORK は orchestrator が docker network connect に使うため定義が必要
MACVLAN_NETWORK=hackbento-vm
IP_POOL_START=192.168.180.200
IP_POOL_END=192.168.180.230
