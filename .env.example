# ===== HackBento 環境設定テンプレート =====
# cp .env.example .env  してから値を埋めてください

# --- サーバ ---
DOMAIN=localhost
SCHEME=http
PORT=8000

# --- DB ---
DATABASE_URL=sqlite+aiosqlite:////data/db/hackbento.db

# --- LDAP ---
LDAP_ENABLED=false
LDAP_URI="ldap://example.com:389"
LDAP_TOP_DOMAIN="dc=example,dc=com"
LDAP_BIND_PASSWORD=
LDAP_USER_FILTER="(uid={username})"
LDAP_MAIL_DOMAIN="example.com"
LDAP_OU_USER="people"
LDAP_OU_GROUP="groups"
LDAP_SSH_ATTR_NAME=

# --- Google OAuth2 ---
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_ALLOWED_DOMAINS=

# --- バックエンド ---
VM_BACKEND=docker

# --- macvlan / VM IPプール ---
# macvlan ネットワーク設定（物理NI・サブネット等）は docker-compose.yml の networks: で管理
# MACVLAN_NETWORK は orchestrator が docker network connect に使うため定義が必要
MACVLAN_NETWORK=hackbento-vm
IP_POOL_START=192.168.181.200
IP_POOL_END=192.168.181.230
